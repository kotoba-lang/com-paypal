  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "SAVED",
              "APPROVED",
              "VOIDED",
              "COMPLETED",
              "PAYER_ACTION_REQUIRED"
            ]
          },
          "intent": {
